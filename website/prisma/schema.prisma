generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminSettings {
  id           String   @id @default("admin")
  passwordHash String
  updatedAt    DateTime
}

model AgentActivity {
  id         String   @id @default(cuid())
  action     String
  category   String
  details    String?
  occurredAt DateTime
  syncedAt   DateTime @default(now())

  @@index([category])
  @@index([occurredAt])
}

model AgentCronTrigger {
  id          String    @id @default(cuid())
  jobId       String
  jobName     String
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  result      String?

  @@index([createdAt])
  @@index([status])
}

model AgentMemory {
  id       String    @id @default(cuid())
  filename String    @unique
  content  String
  fileDate DateTime?
  syncedAt DateTime  @default(now())

  @@index([fileDate])
}

model AgentSchedule {
  id         String    @id @default(cuid())
  jobId      String    @unique
  name       String
  schedule   String
  timezone   String?
  nextRunAt  DateTime?
  lastRunAt  DateTime?
  lastStatus String?
  enabled    Boolean   @default(true)
  syncedAt   DateTime  @default(now())

  @@index([name])
}

model AgentTask {
  id        String    @id @default(cuid())
  section   String
  content   String
  completed Boolean   @default(false)
  sortOrder Int       @default(0)
  syncedAt  DateTime  @default(now())
  tid       String?   @unique
  project   String?
  mode      String?   // build | growth | content | admin
  size      String?   // S | M | L
  taskStatus String?  // inbox | ready | in_progress | waiting_on_jamie | waiting_on_agent | waiting_external | blocked | done | archived
  blockedBy String?
  dueDate   DateTime?
  owner     String?

  @@index([completed])
  @@index([section])
  @@index([taskStatus])
  @@index([owner])
  @@index([project])
}

model MetricsHistory {
  id         String   @id
  projectId  String
  mrr        Decimal  @db.Decimal(10, 2)
  users      Int
  recordedAt DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, recordedAt])
}

model Post {
  id            String         @id
  slug          String         @unique
  title         String
  excerpt       String
  tags          String[]
  readTime      Int
  publishedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime
  content       String?
  postType      String         @default("manual")
  projectId     String?
  published     Boolean        @default(false)
  contentPillar ContentPillar?
  phase         ProjectPhase?
  postTypeEnum  PostTypeEnum?
  targetPersona TargetPersona?
  project       Project?       @relation(fields: [projectId], references: [id])

  @@index([contentPillar])
  @@index([phase])
  @@index([postType])
  @@index([projectId])
  @@index([publishedAt])
  @@index([targetPersona])
}

model Project {
  id               String           @id
  slug             String           @unique
  name             String
  description      String
  longDescription  String?
  url              String
  techStack        String[]
  category         Category
  featured         Boolean          @default(false)
  mrr              Decimal          @default(0) @db.Decimal(10, 2)
  users            Int              @default(0)
  status           ProjectStatus    @default(LIVE)
  problemStatement String?
  solutionApproach String?
  lessonsLearned   String?
  screenshots      String[]
  launchedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  githubToken      String?
  githubUrl        String?
  lastSynced       DateTime?
  trackProgress    Boolean          @default(false)
  customMetrics    Json?
  projectType      ProjectType      @default(SAAS)
  currentPhase     ProjectPhase?
  techStackDetails String?
  timelineEvents   Json?
  metricsHistory   MetricsHistory[]
  posts            Post[]
  goals            Goal[]
  issues           Issue[]
  projectId        String?          @unique
  program          String?
  keyResult        String?
  tier             String?          // NOW | NEXT | LATER
  health           String?          // green | amber | red
  killDate         DateTime?
  nextProofPoint   String?
  progress         String?
  blocker          String?

  @@index([category])
  @@index([currentPhase])
  @@index([featured])
  @@index([trackProgress])
  @@index([tier])
  @@index([health])
}

enum Category {
  AI_TOOLS
  FRAMEWORKS
  EDUCATION
  MARKETPLACE
  OTHER
  PRODUCTIVITY
  FINANCE
  WELLBEING
}

enum ContentPillar {
  JOURNEY
  FRAMEWORK
  TOOL
  COMMUNITY
}

enum PostTypeEnum {
  PROGRESS_UPDATE
  MILESTONE
  FAILURE
  TUTORIAL
  CASE_STUDY
  GENERAL
}

enum ProjectPhase {
  IDEATION
  MVP
  LAUNCH
  GROWTH
  MAINTENANCE
  ARCHIVED
  PAUSED
}

enum ProjectStatus {
  ACTIVE
  BETA
  PLANNING
  ARCHIVED
  RESEARCH
  DESIGN
  BUILD
  MVP
  LIVE
}

enum ProjectType {
  SAAS
  TRADING
  OPEN_SOURCE
  CONTENT
  PERSONAL
  MARKETPLACE
  BENCHMARK
}

enum TargetPersona {
  CORPORATE_ESCAPIST
  SERVICE_PROVIDER
  BUILDER
  ALL
}

model Issue {
  id          String    @id @default(cuid())
  type        String
  title       String
  description String?
  severity    String
  status      String    @default("open")
  source      String    @default("manual")
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id])
  assignedTo  String?
  resolution  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
  @@index([projectId])
}

model AgentStatus {
  id             String   @id @default(cuid())
  agentId        String   @unique
  name           String
  machine        String   @default("unknown")
  model          String   @default("sonnet")
  status         String   @default("offline")
  lastActiveAt   DateTime @default(now())
  currentTask    String?
  tasksCompleted Int      @default(0)
  tasksThisWeek  Int      @default(0)
  projectId      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
  role           String?
  queueSize      Int      @default(0)
  exceptions     Int      @default(0)
  mcDuties       String?

  @@index([status])
  @@index([lastActiveAt])
}

model Goal {
  id           String    @id @default(cuid())
  name         String
  description  String?
  metric       String
  currentValue Float
  targetValue  Float
  unit         String
  category     String
  status       String    @default("on_track")
  deadline     DateTime?
  startDate    DateTime  @default(now())
  projectId    String?
  project      Project?  @relation(fields: [projectId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  goalId       String?   @unique
  parentId     String?
  horizon      String?
  confidence   String?
  dueDate      DateTime?

  @@index([category])
  @@index([status])
  @@index([projectId])
}

// === Mission Control V2 Models ===

model HitlItem {
  id              String    @id @default(cuid())
  tid             String?
  description     String
  type            String    // quick_yes_no | review_and_edit | decision | approve_with_conditions
  priority        String    // P0 | P1 | P2
  requestingAgent String?
  project         String?
  waitingSince    DateTime
  blocks          String?
  status          String    @default("open") // open | resolved
  outcome         String?   // approved | approved_with_changes | rework_requested | deferred | rejected
  resolvedAt      DateTime?
  resolvedNotes   String?
  syncedAt        DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([priority])
  @@index([waitingSince])
}

model RecurringOp {
  id            String    @id @default(cuid())
  rid           String    @unique
  operation     String
  owner         String
  machine       String?
  cadence       String
  lastCompleted DateTime?
  nextDue       DateTime?
  sla           String?
  status        String    @default("active")
  syncedAt      DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([nextDue])
}

model SystemHealth {
  id               String    @id @default(cuid())
  system           String    @unique
  owner            String
  machine          String?
  checkMethod      String?
  expectedInterval String?
  lastSuccess      DateTime?
  status           String    @default("unknown") // green | amber | red | unknown
  alertThreshold   String?
  syncedAt         DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
}

model EventLog {
  id        String   @id @default(cuid())
  timestamp DateTime
  actor     String
  entity    String   // task | project | goal | hitl | decision
  entityId  String
  action    String   // status_change | created | resolved | completed
  fromValue String?
  toValue   String?
  reason    String?
  project   String?
  createdAt DateTime @default(now())

  @@index([timestamp])
  @@index([entityId])
  @@index([actor])
  @@index([entity])
}

model Decision {
  id         String    @id @default(cuid())
  did        String    @unique
  date       DateTime
  title      String
  owner      String
  context    String?
  chosen     String?
  reviewDate DateTime?
  syncedAt   DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model McMetric {
  id       String   @id @default(cuid())
  group    String   // strategic | execution | agent_performance | product_business
  name     String
  current  String?
  target   String?
  status   String?  // ok | needs_attention | below | at_risk
  syncedAt DateTime @default(now())

  @@unique([group, name])
  @@index([group])
}
